# Event Management environment template
#
# Copy the backend keys into: backend/.env
# Copy the frontend keys into: front/.env
# and adjust values for your machine.

# ----------------------------
# Backend (Django)
# ----------------------------
DJANGO_SECRET_KEY=replace-with-a-strong-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Event System <your-email@example.com>

CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173

# ----------------------------
# Frontend (Vite)
# ----------------------------
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:9000
